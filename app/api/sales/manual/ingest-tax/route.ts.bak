import { NextResponse } from "next/server";
import outputs from "@/amplify_outputs.json";

const DATA_URL = (outputs as any)?.data?.url;
const DATA_API_KEY = (outputs as any)?.data?.api_key;
type GqlResp<T> = { data?: T; errors?: { message: string }[] };

async function gql<T>(query: string, variables?: any): Promise<T> {
  if (!DATA_URL || !DATA_API_KEY) throw new Error("Missing DATA_URL / DATA_API_KEY");

  const res = await fetch(DATA_URL, {
    method: "POST",
    headers: {
      "content-type": "application/json",
      "x-api-key": DATA_API_KEY,
    },
    body: JSON.stringify({ query, variables }),
  });

  const json = (await res.json().catch(() => ({}))) as GqlResp<T>;
  if (!res.ok || json.errors?.length) {
    throw new Error(json.errors?.map((e) => e.message).join(" | ") || `HTTP ${res.status}`);
  }
  return json.data as T;
}

const CREATE_SALESLINE = /* GraphQL */ `
  mutation CreateSalesLine($input: CreateSalesLineInput!) {
    createSalesLine(input: $input) {
      marketplaceId
      orderId
      sku
    }
  }
`;

const LIST_SUPPLIERMAP = /* GraphQL */ `
  query ListSupplierMap($filter: ModelSupplierMapFilterInput, $limit: Int) {
    listSupplierMaps(filter: $filter, limit: $limit) {
      items { sku shortTitle productCost shippingCost prepCost updatedAtIso }
    }
  }
`;

function previewLine(line: string, max = 200) {
  const s = String(line ?? "");
  return s.length > max ? s.slice(0, max) + "â€¦" : s;
}

function parseCsvLine(line: string): string[] {
  // simple CSV parser (handles quoted commas)
  const out: string[] = [];
  let cur = "";
  let inQ = false;
  for (let i = 0; i < line.length; i++) {
    const ch = line[i];
    if (ch === '"' && line[i + 1] === '"') {
      cur += '"';
      i++;
      continue;
    }
    if (ch === '"') {
      inQ = !inQ;
      continue;
    }
    if (ch === "," && !inQ) {
      out.push(cur);
      cur = "";
      continue;
    }
    cur += ch;
  }
  out.push(cur);
  return out.map((s) => s.trim());
}

function toIsoMaybe(s: string): string | null {
  const t = s?.trim();
  if (!t) return null;
  const d = new Date(t);
  if (Number.isNaN(d.getTime())) return null;
  return d.toISOString();
}

function numMaybe(s: string): number | null {
  const t = s?.trim();
  if (!t) return null;
  const n = Number(t);
  return Number.isFinite(n) ? n : null;
}

export async function POST(req: Request) {
  try {
    const { searchParams } = new URL(req.url);
    const mid = String(searchParams.get("mid") ?? "").trim();
    const currency = String(searchParams.get("cur") ?? "").trim(); // optional override

    if (!mid) return NextResponse.json({ ok: false, error: "Missing mid" }, { status: 400 });

    const csvText = await req.text();
    if (!csvText?.trim()) return NextResponse.json({ ok: false, error: "Empty CSV body" }, { status: 400 });

    const lines = csvText.split(/\r?\n/).filter((l) => l.trim().length);
    if (lines.length < 2) return NextResponse.json({ ok: false, error: "CSV must include header + rows" }, { status: 400 });

    const header = parseCsvLine(lines[0]).map((h) => h.toLowerCase());

    function idxAny(...names: string[]) {
      for (const n of names) {
        const i = header.indexOf(n.toLowerCase());
        if (i >= 0) return i;
      }
      return -1;
    }

    const iOrder = idxAny("amazon order id", "order id");
    const iSku = idxAny("merchant sku");
    const iTitle = idxAny("title", "product name");
    const iQty = idxAny("dispatched quantity");

    const iPurchase = idxAny("purchase date");
    const iShip = idxAny("shipment date");
    const iReporting = idxAny("reporting date");

    const iCur = idxAny("currency");
    const iItemPrice = idxAny("item price");
    const iItemTax = idxAny("item tax");
    const iShipPrice = idxAny("delivery price");
    const iShipTax = idxAny("delivery tax");
    const iPromo = idxAny("promotion discount");
    const iPromoTax = idxAny("promotion discount tax");

    if (iOrder < 0 || iSku < 0 || iQty < 0) {
      return NextResponse.json(
        {
          ok: false,
          error:
            "Missing required columns. Need: Amazon Order Id (or Order ID), Merchant SKU, Dispatched Quantity",
        },
        { status: 400 }
      );
    }

    // Cache suppliermap for quick lookup
    const smCache = new Map<string, any>();

    let inserted = 0;
    let skipped = 0;
    const rowErrors: any[] = [];

    for (let r = 1; r < lines.length; r++) {
      const rawLine = lines[r];
      const cols = parseCsvLine(rawLine);

      const orderId = String(cols[iOrder] ?? "").trim();
      const sku = String(cols[iSku] ?? "").trim();
      const qty = Number(cols[iQty] ?? 0);

      if (!orderId || !sku || !Number.isFinite(qty) || qty <= 0) {
        skipped++;
        continue;
      }

      try {
        // SupplierMap lookup
        let sm = smCache.get(sku);
        if (!sm) {
          const smRes = await gql<{ listSupplierMaps: { items: any[] } }>(LIST_SUPPLIERMAP, {
            filter: { sku: { eq: sku } },
            limit: 1,
          });
          sm = smRes?.listSupplierMaps?.items?.[0] ?? null;
          smCache.set(sku, sm);
        }

        const cur = currency || String(cols[iCur] ?? "").trim() || "GBP";

        const input: any = {
          marketplaceId: mid,
          orderId,
          sku,
          currency: cur,
          qty: Math.trunc(qty),

          purchaseAtIso: iPurchase >= 0 ? toIsoMaybe(cols[iPurchase] ?? "") : null,
          shippedAtIso: iShip >= 0 ? toIsoMaybe(cols[iShip] ?? "") : null,
          reportingAtIso: iReporting >= 0 ? toIsoMaybe(cols[iReporting] ?? "") : null,

          listingTitle: iTitle >= 0 ? String(cols[iTitle] ?? "").trim() : null,

          itemPrice: iItemPrice >= 0 ? numMaybe(cols[iItemPrice] ?? "") : null,
          itemTax: iItemTax >= 0 ? numMaybe(cols[iItemTax] ?? "") : null,
          shippingPrice: iShipPrice >= 0 ? numMaybe(cols[iShipPrice] ?? "") : null,
          shippingTax: iShipTax >= 0 ? numMaybe(cols[iShipTax] ?? "") : null,
          promoDiscount: iPromo >= 0 ? numMaybe(cols[iPromo] ?? "") : null,
          promoDiscountTax: iPromoTax >= 0 ? numMaybe(cols[iPromoTax] ?? "") : null,

          shortTitle: sm?.shortTitle ?? null,

          supplierCostExVat: sm?.productCost ?? null,
          inboundShipping: sm?.shippingCost ?? null,
          prepCost: sm?.prepCost ?? null,
        };

        await gql(CREATE_SALESLINE, { input });
        inserted++;
      } catch (e: any) {
        const msg = String(e?.message ?? e);

        // Duplicate create (Amplify uses a conditional put): treat as skip (idempotent)
        if (msg.toLowerCase().includes("conditional request failed")) {
          skipped++;
          continue;
        }

        rowErrors.push({
          row: r,
          orderId,
          sku,
          error: msg,
          line: previewLine(rawLine),
        });
      }
    }

    return NextResponse.json({
      ok: true,
      mid,
      inserted,
      skipped,
      rowErrors: rowErrors.slice(0, 25),
      rowErrorsCount: rowErrors.length,
    });
  } catch (e: any) {
    return NextResponse.json({ ok: false, error: e?.message || String(e) }, { status: 500 });
  }
}

